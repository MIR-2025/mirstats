<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-5 text-center">
    <i class="bi bi-x-circle display-4 text-danger"></i>
    <h1 class="h4 mt-3"><%= typeof message !== 'undefined' && message ? 'Try again' : 'Link expired' %></h1>
    <p class="text-muted">
      <%= typeof message !== 'undefined' && message ? message : 'This sign-in link is invalid, already used, or expired.' %>
    </p>
    <a href="/auth/login" class="btn btn-primary mt-2">Request a new link</a>
  </div>
</div>

<%- include('../partials/footer') %>
