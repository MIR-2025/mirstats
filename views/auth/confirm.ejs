<div class="row justify-content-center">
  <div class="col-md-5 text-center">
    <h1 class="h4 mb-3">Confirm sign in</h1>
    <p class="text-muted">Click below to finish signing in as <strong><%= email %></strong>.</p>

    <form action="/auth/confirm/<%= token %>" method="post">
      <button type="submit" class="btn btn-primary btn-lg w-100">Sign in</button>
    </form>
  </div>
</div>

