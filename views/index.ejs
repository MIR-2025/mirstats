<%- include('partials/header') %>

<div class="dash" data-bs-theme="dark">

  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <h1 class="h5 mb-0 teal">MIR SENTINEL</h1>
    <div class="d-flex align-items-center gap-3">
      <div class="small muted">
        upstream <span id="upstream" class="pulse-bad">…</span>
        &middot; uptime <span id="uptime">–</span>
        &middot; <span id="lines">0</span> lines parsed
      </div>
      <button id="theme-toggle" type="button" class="theme-toggle" title="Switch to light">☾</button>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="row g-2 mb-3" id="cards">
    <div class="col-6 col-md">
      <div class="card stat-card h-100"><div class="card-body py-2">
        <div class="value teal" id="c-req">0</div><div class="label">requests</div>
        <div class="sub" id="c-reqsub">&nbsp;</div>
      </div></div>
    </div>
    <div class="col-6 col-md">
      <div class="card stat-card h-100"><div class="card-body py-2">
        <div class="value green" id="c-rate">0</div><div class="label">req / min</div>
        <div class="sub">last 60s</div>
      </div></div>
    </div>
    <div class="col-6 col-md">
      <div class="card stat-card h-100"><div class="card-body py-2">
        <div class="value yellow" id="c-err">0%</div><div class="label">error rate</div>
        <div class="sub">4xx + 5xx</div>
      </div></div>
    </div>
    <div class="col-6 col-md">
      <div class="card stat-card h-100"><div class="card-body py-2">
        <div class="value red" id="c-atk">0</div><div class="label">attacks</div>
        <div class="sub" id="c-atksub">&nbsp;</div>
      </div></div>
    </div>
    <div class="col-6 col-md">
      <div class="card stat-card h-100"><div class="card-body py-2">
        <div class="value crit" id="c-alert">0</div><div class="label">alerts</div>
        <div class="sub">incident bursts</div>
      </div></div>
    </div>
    <div class="col-6 col-md">
      <div class="card stat-card h-100"><div class="card-body py-2">
        <div class="value muted" id="c-bots">0</div><div class="label">bot hits</div>
        <div class="sub" id="c-assetsub">&nbsp;</div>
      </div></div>
    </div>
  </div>

  <div class="row g-3">
    <!-- left column -->
    <div class="col-lg-7">
      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
          <span class="d-flex align-items-center"><span class="acc-h" role="button" data-bs-toggle="collapse" data-bs-target="#acc-rpm" aria-expanded="true" aria-controls="acc-rpm"><span class="acc-caret">▸</span>requests / minute &middot; history</span><span id="rpm-ip" class="rpm-ip"></span></span>
          <span class="d-flex align-items-center gap-2">
            <input type="datetime-local" id="rpm-date" class="rpm-date" title="Jump to a date / time">
            <button type="button" id="rpm-now" class="rpm-now" title="Jump to the live edge">now</button>
            <span class="muted" id="rpm-avg" title="average req/min over the last 60 minutes"></span>
            <span class="muted" id="rpm-peak"></span>
          </span>
        </div>
        <div id="acc-rpm" class="collapse show">
        <div class="card-body">
          <div class="rpm-wrap">
            <div id="rpm"></div>
            <span id="rpm-end-l" class="rpm-end" title="hits in the left-edge (oldest visible) bar"></span>
            <span id="rpm-end-r" class="rpm-end" title="hits in the right-edge (newest visible) bar"></span>
          </div>
          <div id="rpm-axis-wrap" class="rpm-axis-wrap"><div id="rpm-axis" class="rpm-axis"></div></div>
          <div class="status-bar mt-3" id="status-bar"></div>
          <div class="d-flex justify-content-between small muted mt-1" id="status-legend"></div>
        </div>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span class="acc-h" role="button" data-bs-toggle="collapse" data-bs-target="#acc-tail" aria-expanded="true" aria-controls="acc-tail"><span class="acc-caret">▸</span>live tail</span>
          <span class="d-flex align-items-center gap-2">
            <span id="tail-pin" class="tail-pin"></span>
            <span id="tail-filter" class="muted"></span>
            <input type="text" id="tail-ip" class="tail-ip" placeholder="ip / .0/24" autocomplete="off" spellcheck="false" title="Filter tail by IP or /24">
            <button id="tail-clear" type="button" class="tail-clear" title="Clear the saved tail">clear</button>
          </span>
        </div>
        <div id="acc-tail" class="collapse show"><div class="card-body py-2"><div id="tail"></div></div></div>
      </div>

      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
          <span>AI analysis</span>
          <span class="d-flex align-items-center gap-2">
            <input type="date" id="ai-date" class="rpm-date" title="Day to analyze">
            <button type="button" id="ai-run" class="rpm-now">analyze</button>
            <button type="button" id="ai-refresh" class="rpm-now" title="Re-run, ignoring cache">↻</button>
            <button type="button" id="ai-pdf" class="rpm-now" title="Download as PDF" disabled>PDF</button>
          </span>
        </div>
        <div class="card-body py-2"><div id="ai-out" class="muted small">Pick a day and click analyze.</div></div>
      </div>

      <div class="card mb-3">
        <div class="card-header acc-toggle" role="button" data-bs-toggle="collapse" data-bs-target="#acc-alerts" aria-expanded="true" aria-controls="acc-alerts">
          <span>recent alerts</span><span class="acc-caret">▸</span>
        </div>
        <div id="acc-alerts" class="collapse show">
          <div class="card-body py-2"><div id="alerts"><div class="muted small">none yet</div></div></div>
        </div>
      </div>
    </div>

    <!-- right column -->
    <div class="col-lg-5">
      <div class="card mb-3">
        <div class="card-header acc-toggle" role="button" data-bs-toggle="collapse" data-bs-target="#acc-ipq" aria-expanded="true" aria-controls="acc-ipq">
          <span>IP search</span><span class="acc-caret">▸</span>
        </div>
        <div id="acc-ipq" class="collapse show">
        <div class="card-body py-2">
          <div class="ipq-row">
            <input type="text" id="ipq" class="ipq-input" placeholder="IP or /24 prefix — e.g. 195.178.110" autocomplete="off" spellcheck="false">
          </div>
          <div class="ipq-row">
            <input type="date" id="ipq-from" class="rpm-date" title="From date">
            <input type="date" id="ipq-to" class="rpm-date" title="To date">
          </div>
          <div id="ipq-list" class="ipq-list"></div>
          <div id="ipq-result" class="ipq-result"></div>
        </div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header acc-toggle" role="button" data-bs-toggle="collapse" data-bs-target="#acc-sources" aria-expanded="true" aria-controls="acc-sources">
          <span>sources</span><span class="acc-caret">▸</span>
        </div>
        <div id="acc-sources" class="collapse show">
          <div class="card-body py-2"><div id="sources"></div></div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header acc-toggle collapsed" role="button" data-bs-toggle="collapse" data-bs-target="#acc-paths" aria-expanded="false" aria-controls="acc-paths">
          <span>top paths</span><span class="acc-caret">▸</span>
        </div>
        <div id="acc-paths" class="collapse">
          <div class="card-body py-2"><table class="dash-table"><tbody id="paths"></tbody></table></div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header acc-toggle collapsed" role="button" data-bs-toggle="collapse" data-bs-target="#acc-ips" aria-expanded="false" aria-controls="acc-ips">
          <span>top IPs</span><span class="acc-caret">▸</span>
        </div>
        <div id="acc-ips" class="collapse">
          <div class="card-body py-2"><table class="dash-table"><tbody id="ips"></tbody></table></div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header red acc-toggle collapsed" role="button" data-bs-toggle="collapse" data-bs-target="#acc-attackers" aria-expanded="false" aria-controls="acc-attackers">
          <span>top attackers</span><span class="acc-caret">▸</span>
        </div>
        <div id="acc-attackers" class="collapse">
          <div class="card-body py-2"><table class="dash-table"><tbody id="attackers"></tbody></table></div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header acc-toggle collapsed" role="button" data-bs-toggle="collapse" data-bs-target="#acc-reports" aria-expanded="false" aria-controls="acc-reports">
          <span>auto-reports</span><span class="acc-caret">▸</span>
        </div>
        <div id="acc-reports" class="collapse">
          <div class="card-body py-2"><div id="reports"><div class="muted small">none yet</div></div></div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header acc-toggle collapsed" role="button" data-bs-toggle="collapse" data-bs-target="#acc-methods" aria-expanded="false" aria-controls="acc-methods">
          <span>methods</span><span class="acc-caret">▸</span>
        </div>
        <div id="acc-methods" class="collapse">
          <div class="card-body py-2"><div id="methods"></div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
