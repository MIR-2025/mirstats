# ── mirstats config. Copy to .env, then edit. Never commit .env. ──

# HTTP server
PORT=26613
NODE_ENV=production
SITE_NAME=MIR Sentinel
APP_URL=http://localhost:26613

# Dashboard source-color palette. Blank/unset = a generic example palette
# (api/web/auth/…); set to "mir" for mir.org's hues. Edit the maps in
# public/js/app.js (sourcePalette()) to define your own.
# SOURCE_PALETTE=

# Upstream log feed to consume. mirstats connects to this Socket.io server as a
# client, emits `subscribe:logs`, and parses each `log:line` event it receives.
# Point this at YOUR feed (see README "Upstream feed").
LOG_SOURCE_URL=http://localhost:51211

# Chart bar size in minutes (1 = per-minute bars; 5 = 5-minute bars, …).
# RPM_BUCKET_MIN=1

# Dashboard auth (HTTP Basic). Leave BOTH blank to run open — only do that if
# the dashboard is not reachable from the internet.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# Session secret (used by the bundled session/auth layer).
SESSION_SECRET=change-me-to-a-long-random-string

# Storage for the session/auth layer (see README "Requirements").
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=mirstats
REDIS_URL=redis://127.0.0.1:6379

# Optional SMTP for the scaffold's magic-link email. If unset, links are printed
# to the console instead of emailed.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=

# ── Attacker auto-reporting (optional) ──
# When one IP crosses REPORT_THRESHOLD attack hits, mirstats can report it to
# AbuseIPDB (enriched with an ipinfo lookup + a few sample log lines) and surface
# it on the dashboard. Submission only happens when AUTO_REPORT is truthy AND
# ABUSEIPDB_KEY is set; otherwise it just flags the IP on the dashboard.
AUTO_REPORT=0
# Fingerprint gate: report after this many credential-probe hits (.env / .git /
# wp-config / .aws/credentials / secrets.json …). Only attack-pattern paths are
# counted, so a low value is safe — legit users never request these. 10–15
# catches a typical secrets-scanner (they probe ~20-40 paths).
REPORT_THRESHOLD=15
REPORT_COOLDOWN_MS=21600000          # re-report a persistent attacker after this (6h)
# Burst gate (optional): also report any IP doing BURST_THRESHOLD 4xx to ONE
# source within BURST_WINDOW_MS, regardless of path. This counts ALL 4xx, so keep
# it tight to avoid false positives — 25-in-10s needs a sustained ~2.5/sec
# (abnormal for humans) yet still catches scanners that spread probes across a
# few seconds. Widen the window for slower scans at some false-positive cost.
# BURST_THRESHOLD=25
# BURST_WINDOW_MS=10000
# FLAG_PHP_PROBES=0                  # 1 = treat any .php request as an attack (only if you serve NO PHP)
# ABUSEIPDB_CATEGORIES=21            # comma list; 21 = Web App Attack (see AbuseIPDB docs)
# REPORT_SKIP_IPS=                   # comma list of IPs to never report (e.g. your own egress)
# REPORT_DATA_DIR=                   # where dedup state + reports.jsonl audit log live (default ./data)

# ── AI log analysis (optional) ──
# Powers the "AI analysis" panel, which summarizes a chosen day's traffic via the
# Anthropic API (server-side; the key is never sent to the browser). Leave blank
# to disable — the panel shows a hint instead. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# AbuseIPDB APIv2 key — create a free account, then make a key at
#   https://www.abuseipdb.com/account/api
# ABUSEIPDB_KEY=

# ipinfo token (Lite API, free) for geo/ASN enrichment — sign up, then copy from
#   https://ipinfo.io/account/token
# IPINFO_KEY=

# ── Infrastructure health (optional) ──
# Pulls CPU/RAM/disk/load/net from a few Linux servers over SSH (key-only) and
# shows them in the "infrastructure" card. List the servers in a JSON file (see
# data/infra-hosts.example.json); disabled if the file is absent/empty. The SSH
# user only needs to read /proc + run df/nproc — no agent is installed.
# INFRA_HOSTS_FILE=data/infra-hosts.json   # path to the host list
# INFRA_SSH_KEY=                            # fallback key for all hosts (e.g. ~/.ssh/id_rsa);
#                                           # omit to use ssh's normal resolution (~/.ssh/config,
#                                           # default keys, agent). No key is ever copied.
# INFRA_POLL_MS=10000                       # how often to poll each host (ms, min 1000)
# INFRA_SSH_TIMEOUT=8                        # per-host ssh timeout (seconds)
# INFRA_CPU_WARN=90                          # flag a host when a metric crosses these
# INFRA_MEM_WARN=90
# INFRA_DISK_WARN=90
# INFRA_LOAD_WARN=1.5                        # load average per core
